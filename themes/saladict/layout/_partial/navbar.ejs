        </div>

        <div class="navbar-item site-navbar-inkora">
          <button class="site-navbar-inkora-trigger" type="button" aria-expanded="false" aria-controls="site-navbar-inkora-panel">
            <%- github_emoji('book') %><%= __('nav_pdf_translate') %>
          </button>
          <div class="site-navbar-inkora-panel" id="site-navbar-inkora-panel" hidden>
            <div class="site-navbar-inkora-heading">
              <img class="site-navbar-inkora-icon" src="https://pdf.oomol.com/images/logo.png" alt="Inkora" width="40" height="40">
              <div>
                <strong><%= __('inkora_title') %></strong>
                <span><%= __('inkora_tagline') %></span>
              </div>
            </div>
            <p><%= __('inkora_desc') %></p>
